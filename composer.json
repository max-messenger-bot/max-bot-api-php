{
    "name": "max-messenger-bot/max-bot-api-php",
    "description": "PHP SDK for the Max Messenger Bot API",
    "keywords": [
        "max",
        "messenger",
        "bot",
        "max messenger",
        "max bot",
        "api",
        "sdk",
        "php"
    ],
    "type": "library",
    "license": "MIT",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "MaxMessenger\\Bot\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Eugene Makhaev",
            "email": "mj4444@mail.ru"
        }
    ],
    "support": {
        "email": "mj4444@mail.ru",
        "chat": "https://t.me/mj4444ru"
    },
    "require": {
        "php": "^8.2",
        "ext-mbstring": "*",
        "mj4444/simple-http-client": "^0.2"
    },
    "require-dev": {
        "codeception/codeception": "^5.3",
        "codeception/module-asserts": "*",
        "friendsofphp/php-cs-fixer": "^3.95",
        "vimeo/psalm": "^6.16"
    },
    "scripts": {
        "test": "codecept run",
        "psalm": "psalm",
        "php-cs-fixer": "php-cs-fixer check --diff",
        "php-cs-fixer-fix": "php-cs-fixer fix"
    },
    "bin": [
        "bin/max-chats",
        "bin/max-debug",
        "bin/max-delete-chats",
        "bin/max-subscribe",
        "bin/max-subscribes",
        "bin/max-unsubscribe",
        "bin/polling-to-webhook"
    ],
    "config": {
        "sort-packages": true
    }
}
