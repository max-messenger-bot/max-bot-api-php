<?xml version="1.0"?>
<ruleset name="MaxBotApi">
    <description>PSR-12 coding standard for max-bot-api-php</description>

    <file>bin</file>
    <file>src</file>
    <file>tests</file>

    <arg name="basepath" value="."/>
    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <!-- bin/ — CLI-скрипты: классы без namespace и смешивание объявлений с логикой допустимы -->
    <rule ref="PSR1.Classes.ClassDeclaration.MissingNamespace">
        <exclude-pattern>bin/</exclude-pattern>
    </rule>
    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
        <exclude-pattern>bin/</exclude-pattern>
    </rule>

    <!-- tests/ — _before является стандартным lifecycle-хуком Codeception -->
    <rule ref="PSR2.Methods.MethodDeclaration.Underscore">
        <exclude-pattern>tests/</exclude-pattern>
    </rule>
</ruleset>
