# Long Polling → Webhook Bridge
# Скопируйте этот файл в dev/.polling-to-webhook.conf и заполните параметры

# API ключ бота для Long Polling
API_KEY=your-api-tok

# Полный путь к скрипту-обработчику (webhook handler)
SCRIPT=/path/to/your/webhook.php

# PHP CGI интерпретатор
BIN=/usr/bin/php-cgi

# Секрет для заголовка X-Max-Bot-Api-Secret
SECRET=your-secret-token
