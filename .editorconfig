# editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
max_line_length = 120
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[{Exceptions,HttpClient}.md]
max_line_length = 160

[*.yml]
indent_size = 2

[schema_*.yaml]
indent_size = 2
max_line_length = 80

[QWEN.md]
max_line_length = off
